<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.MapActivity">

    <!-- Coordinator Layout holding all map views -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/coordinatorLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Map Fragment (Full bleed) -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/mapFragment"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Overlay Alerts Container -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="64dp"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Weak GPS Chip -->
            <com.google.android.material.chip.Chip
                android:id="@+id/weakGpsChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/weak_gps"
                android:textColor="@color/white"
                app:chipBackgroundColor="@color/accent"
                app:chipIconTint="@color/white"
                android:visibility="gone"
                app:chipIcon="@android:drawable/stat_sys_warning"
                tools:visibility="visible" />

            <!-- Walk Paused Chip -->
            <com.google.android.material.chip.Chip
                android:id="@+id/walkPausedChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/walk_paused"
                android:textColor="@color/white"
                app:chipBackgroundColor="@color/gray_dark"
                app:chipIconTint="@color/white"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>

        <!-- Location Permission Denied Empty State -->
        <LinearLayout
            android:id="@+id/permissionDeniedContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#E6F5F0E8"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:visibility="gone"
            tools:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍"
                android:textSize="64sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/location_denied_empty_state"
                android:textAlignment="center"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnOpenSettings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:backgroundTint="@color/primary"
                android:text="@string/open_settings"
                android:textColor="@color/white" />
        </LinearLayout>


        <!-- Persistent Bottom Sheet Container (Persistent) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/persistentBottomSheet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:behavior_peekHeight="@dimen/bottom_sheet_peek_height"
            app:cardCornerRadius="24dp"
            app:cardElevation="16dp"
            app:cardBackgroundColor="@color/white"
            app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Bottom Sheet Drag Handle indicator -->
                <View
                    android:layout_width="40dp"
                    android:layout_height="4dp"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginBottom="16dp"
                    android:background="@color/gray_medium" />

                <!-- Metrics Pills Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    android:layout_marginBottom="20dp">

                    <!-- Steps Pill -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:background="@color/gray_light"
                        android:orientation="vertical"
                        android:padding="@dimen/metric_pill_padding"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvStepsVal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvStepsLbl"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/steps"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Distance Pill -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:background="@color/gray_light"
                        android:orientation="vertical"
                        android:padding="@dimen/metric_pill_padding"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvDistanceVal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.00"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Distance (km)"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- Turf Loops Pill -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:background="@color/primary_light"
                        android:orientation="vertical"
                        android:padding="@dimen/metric_pill_padding"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvLoopsVal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Turf loops"
                            android:textColor="@color/primary"
                            android:textSize="12sp" />
                    </LinearLayout>

                </LinearLayout>

                <!-- Second Metrics Pills Row (Revealed when expanded) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    android:layout_marginBottom="20dp">

                    <!-- Cadence Pill -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:background="@color/gray_light"
                        android:orientation="vertical"
                        android:padding="@dimen/metric_pill_padding"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvCadenceVal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvCadenceLbl"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cadence (SPM)"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Elevation Pill -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:background="@color/gray_light"
                        android:orientation="vertical"
                        android:padding="@dimen/metric_pill_padding"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvElevationVal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Climb (m)"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Duration Pill -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:background="@color/gray_light"
                        android:orientation="vertical"
                        android:padding="@dimen/metric_pill_padding"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvLiveDurationVal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00:00"
                            android:textColor="@color/text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Duration"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>

                </LinearLayout>

                <!-- Buttons Layout Container -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">

                    <!-- Start Walk Button (Idle State) -->
                    <Button
                        android:id="@+id/btnStartWalk"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:backgroundTint="@color/primary"
                        android:text="@string/start_walk"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:cornerRadius="16dp"
                        android:visibility="visible" />

                    <!-- Active / Paused Button Container (Side-by-side) -->
                    <LinearLayout
                        android:id="@+id/activeControlsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <!-- Pause / Resume Button -->
                        <Button
                            android:id="@+id/btnPauseResume"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:backgroundTint="@color/gray_medium"
                            android:text="@string/pause"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:cornerRadius="16dp" />

                        <!-- End Walk Button -->
                        <Button
                            android:id="@+id/btnEndWalk"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:backgroundTint="@color/accent"
                            android:text="@string/end_walk"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            app:cornerRadius="16dp" />

                    </LinearLayout>

                </FrameLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Recenter FAB -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabRecenter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="184dp"
            android:contentDescription="@string/recenter"
            android:src="@android:drawable/ic_menu_mylocation"
            app:backgroundTint="@color/white"
            app:tint="@color/primary"
            app:elevation="6dp" />

        <!-- Floating Hamburger FAB Menu Button (Top Left) -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabMenu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:contentDescription="Menu"
            android:src="@android:drawable/ic_menu_sort_by_size"
            app:backgroundTint="@color/white"
            app:tint="@color/primary"
            app:fabSize="mini"
            app:elevation="6dp" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- Navigation Drawer Sidebar -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
